TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: if provided, the bot will use webhooks instead of long polling
# WEBHOOK_URL=https://your-cloud-run-url.a.run.app
# Google Cloud Project ID is usually picked up automatically by the SDKs 
# when running on GCP, but can be set manually if needed for local testing.
GOOGLE_CLOUD_PROJECT=your_project_id
